@page "/"
@using Application.Common
@inject IHttpClientFactory ClientFactory
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="container mt-5">
    @* Encabezado *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-light text-dark">Catálogo de Biblioteca</h2>
        <div class="search-box">
            <div class="input-group input-group-sm">
                <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control border-0 bg-light px-3"
                       placeholder="Buscar autor..." @bind="searchTerm" @bind:event="oninput"
                       style="border-radius: 0 20px 20px 0; width: 220px;" />
            </div>
        </div>
    </div>

    @if (pagedData == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary opacity-50" role="status"></div>
            <p class="text-muted mt-2">Sincronizando biblioteca...</p>
        </div>
    }
    else
    {
        <div class="table-responsive shadow-sm rounded-3 bg-white">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-secondary small text-uppercase">
                    <tr>
                        <th style="width: 50px"></th>
                        <th>Autor</th>
                        <th class="text-center">Total Libros</th>
                        <th class="text-end px-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var autor in pagedData.Items.Where(a => a.NombreCompleto.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)))
                    {
                        var isExpanded = expandedAuthors.Contains(autor.Id);
                        <tr>
                            <td class="text-center">
                                <button class="btn btn-link btn-sm text-secondary p-0 border-0" @onclick="() => ToggleAuthor(autor.Id)">
                                    <i class="bi @(isExpanded ? "bi-chevron-down" : "bi-chevron-right")"></i>
                                </button>
                            </td>

                            <td class="fw-medium">@autor.NombreCompleto</td>

                            <td class="text-center">
                                <span class="badge @(autor.Libros.Count >= 3 ? "bg-warning text-dark" : "bg-info text-white") rounded-pill">
                                    @autor.Libros.Count / 3
                                </span>
                            </td>

                            <td class="text-end px-4">
                                <div class="btn-group me-2 shadow-sm">
                                    <button class="btn btn-outline-primary btn-sm" @onclick="() => EditarAutor(autor.Id)">
                                        <i class="bi bi-pencil-square"></i> Editar
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => EliminarAutor(autor.Id)">
                                        <i class="bi bi-trash3"></i> Eliminar
                                    </button>
                                </div>
                                <button class="btn @(isExpanded ? "btn-dark" : "btn-outline-dark") btn-sm rounded-pill px-3"
                                        @onclick="() => ToggleAuthor(autor.Id)">
                                    <small>@(isExpanded ? "Ocultar Libros" : "Libros del Autor")</small>
                                </button>
                            </td>
                        </tr>

                        @if (isExpanded)
                        {
                            <tr class="bg-light">
                                <td colspan="4" class="p-0 border-0">
                                    <div class="px-5 py-4 border-start border-primary border-4 ms-4 my-2 bg-white shadow-sm rounded mx-3">
                                        @if (autor.Libros.Any())
                                        {
                                            <table class="table table-sm align-middle mb-0">
                                                <thead class="text-muted border-bottom">
                                                    <tr class="small text-uppercase">
                                                        <th>Título</th>
                                                        <th>Año</th>
                                                        <th>Género</th>
                                                        <th class="text-end">Acciones de Libro</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var libro in autor.Libros)
                                                    {
                                                        <tr>
                                                            <td class="py-2">@libro.Titulo</td>
                                                            <td class="text-muted">@libro.Anio</td>
                                                            <td><span class="badge bg-light text-dark fw-normal border">@libro.Genero</span></td>
                                                            <td class="text-end">
                                                                <button class="btn btn-outline-danger btn-sm border-0" title="Eliminar Libro" @onclick="() => EliminarLibro(libro.Id)">
                                                                    <i class="bi bi-x-circle-fill"></i> Eliminar
                                                                </button>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        }
                                        else
                                        {
                                            <div class="text-center py-2">
                                                <span class="text-muted small italic"><i class="bi bi-info-circle me-1"></i> Sin obras registradas.</span>
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        @* Paginación Minimalista *@
        <div class="d-flex justify-content-between align-items-center mt-4 px-2">
            <small class="text-muted">Mostrando página @pagedData.PageNumber de @pagedData.TotalPages</small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    <li class="page-item @(pagedData.PageNumber == 1 ? "disabled" : "")">
                        <button class="page-link border-0 text-dark" @onclick="() => CambiarPagina(pagedData.PageNumber - 1)">
                            <i class="bi bi-chevron-left"></i> Anterior
                        </button>
                    </li>
                    <li class="page-item active"><span class="page-link">@pagedData.PageNumber</span></li>
                    <li class="page-item @(pagedData.PageNumber == pagedData.TotalPages ? "disabled" : "")">
                        <button class="page-link border-0 text-dark" @onclick="() => CambiarPagina(pagedData.PageNumber + 1)">
                            Siguiente <i class="bi bi-chevron-right"></i>
                        </button>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

@code {
    private PagedResult<AutorConLibrosDto>? pagedData;
    private string searchTerm = "";
    private HashSet<int> expandedAuthors = new();
    private int currentPage = 1;

    protected override async Task OnInitializedAsync() => await CargarDatos();

    private void ToggleAuthor(int id)
    {
        if (expandedAuthors.Contains(id)) expandedAuthors.Remove(id);
        else expandedAuthors.Add(id);
    }

    private async Task CambiarPagina(int page)
    {
        currentPage = page;
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        try
        {
            var client = ClientFactory.CreateClient("LibreriaApi");
            pagedData = await client.GetFromJsonAsync<PagedResult<AutorConLibrosDto>>($"api/autores/con-libros?page={currentPage}&pageSize=5");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar datos: {ex.Message}");
        }
    }

    private void EditarAutor(int id) => Navigation.NavigateTo($"/editar-autor/{id}");

    private async Task EliminarAutor(int id)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", "¿Desea aplicar un borrado fisico a este autor y todos sus libros asociados?");
        if (confirmado)
        {
            var client = ClientFactory.CreateClient("LibreriaApi");
            var response = await client.DeleteAsync($"api/autores/{id}");
            if (response.IsSuccessStatusCode) await CargarDatos();
        }
    }

    private async Task EliminarLibro(int id)
    {
        var confirmado = await JS.InvokeAsync<bool>("confirm", "¿Desea eliminar este libro?");

        if (confirmado)
        {
            try
            {
                var client = ClientFactory.CreateClient("LibreriaApi");
                var response = await client.DeleteAsync($"api/libros/{id}");

                if (response.IsSuccessStatusCode)
                {
                    // Si todo sale bien, refrescamos la lista
                    await CargarDatos();
                }
                else
                {
                    // 1. Leemos el ErrorResponse que viene de nuestro BaseApiController
                    var errorData = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                    string mensaje = errorData?.Message ?? "No se pudo eliminar el libro.";

                    // 2. Mostramos el error al usuario
                    await JS.InvokeVoidAsync("alert", $"Error: {mensaje}");
                }
            }
            catch (Exception)
            {
                await JS.InvokeVoidAsync("alert", "Error crítico: No se pudo conectar con el servidor.");
            }
        }
    }
}